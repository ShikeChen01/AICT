# AICT Environment Configuration Template
# Copy to .env (production) or .env.development (local dev) and fill in values.
# See docs/v3/AICT_v3_Implementation_Repository.docx for full configuration reference.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aict:changeme@localhost:5432/aict
DB_SSL_MODE=disable  # disable (local) | require (VM/GKE)

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: change this before any deployment
API_TOKEN=change-me-in-production

# REQUIRED for production: Fernet key for project secrets encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# CORS: comma-separated allowed origins (leave empty for localhost defaults)
# Production example: ALLOWED_ORIGINS=https://app.yourco.com,https://api.yourco.com
ALLOWED_ORIGINS=

# Disable legacy null-owner project access in production
ALLOW_NULL_OWNER_ACCESS=true

# ── Auth (Firebase) ───────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=

# Dev-only test login (set to false in production)
TEST_LOGIN_ENABLED=false
TEST_LOGIN_EMAIL=aicttest@aict.com
TEST_LOGIN_PASSWORD=

# ── LLM Providers ────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Default models
MANAGER_MODEL_DEFAULT=claude-sonnet-4-6
CTO_MODEL_DEFAULT=claude-opus-4-6
ENGINEER_JUNIOR_MODEL=gpt-5.2
ENGINEER_INTERMEDIATE_MODEL=claude-sonnet-4-6
ENGINEER_SENIOR_MODEL=claude-opus-4-6

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
CODE_REPO_URL=
SPEC_REPO_PATH=/data/specs
CODE_REPO_PATH=/data/project

# ── Sandbox Orchestrator (GKE) ────────────────────────────────────────────────
# Set this to use the GKE sandbox orchestrator (v3 default)
SANDBOX_ORCHESTRATOR_HOST=sandbox-orchestrator.sandbox-system.svc.cluster.local
SANDBOX_ORCHESTRATOR_PORT=9090
SANDBOX_ORCHESTRATOR_TOKEN=

# Legacy VM sandbox (leave empty if using GKE)
SANDBOX_VM_HOST=
SANDBOX_VM_INTERNAL_HOST=
SANDBOX_VM_POOL_PORT=9090
SANDBOX_VM_MASTER_TOKEN=

# ── RAG / Knowledge Base (Voyage AI) ─────────────────────────────────────────
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENV=production
AUTO_RUN_MIGRATIONS_ON_STARTUP=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
USE_CLOUD_LOGGING=false
